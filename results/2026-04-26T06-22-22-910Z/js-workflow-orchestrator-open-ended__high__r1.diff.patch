+function createStepState(definition, index) {
+  return {
+    index,
+    task: definition.task,
+    definition,
+    status: 'queued',
+    attempts: [],
+    input: undefined,
+    output: undefined,
+    error: null,
+    startedAt: null,
+    finishedAt: null,
+    updatedAt: null,
+    durationMs: null,
+    nextAttemptAt: null,
+  };
+}
+
+function resolveStepInput(definition, job, step, attempt, signal) {
+  if (!Object.prototype.hasOwnProperty.call(definition, 'input')) return job.currentInput;
+  if (typeof definition.input !== 'function') return definition.input;
+  return definition.input(job.currentInput, {
+    job,
+    step,
+    attempt: attempt.attempt,
+    signal,
+    workflowInput: job.input,
+  });
+}
+
+function getStepRetries(definition, job, defaults) {
+  return normalizeNonNegativeInteger(definition.retries ?? job.options.retries ?? defaults.retries ?? 0, 'retries');
+}
+
+function getStepTimeoutMs(definition, job, defaults) {
+  return normalizeOptionalNonNegativeNumber(
+    definition.timeoutMs ?? job.options.stepTimeoutMs ?? defaults.stepTimeoutMs,
+    'step timeoutMs',
+  );
+}
+
+function calculateBackoffMs(definition, job, defaults, failedAttemptNumber) {
+  const base = normalizeOptionalNonNegativeNumber(
+    definition.retryDelayMs ?? job.options.retryDelayMs ?? defaults.retryDelayMs,
+    'retryDelayMs',
+  ) ?? 0;
+  const factor = normalizeFiniteNumber(
+    definition.retryBackoffFactor ?? job.options.retryBackoffFactor ?? defaults.retryBackoffFactor ?? 1,
+    'retryBackoffFactor',
+  );
+  const max = normalizeOptionalNonNegativeNumber(
+    definition.maxRetryDelayMs ?? job.options.maxRetryDelayMs ?? defaults.maxRetryDelayMs,
+    'maxRetryDelayMs',
+  );
+  const raw = base * Math.max(1, factor) ** Math.max(0, failedAttemptNumber - 1);
+  return Math.min(max ?? raw, raw);
+}
+
+async function runWithAbort(promise, signal) {
+  if (!signal) return promise;
+  if (signal.aborted) throw abortReason(signal);
+
+  let abortListener;
+  const abortPromise = new Promise((_, reject) => {
+    abortListener = () => reject(abortReason(signal));
+    signal.addEventListener('abort', abortListener, { once: true });
+  });
+
+  try {
+    return await Promise.race([promise, abortPromise]);
+  } finally {
+    signal.removeEventListener('abort', abortListener);
+    // Avoid noisy unhandled rejections from work that loses the race after timeout
+    // or cancellation. The underlying function cannot be killed by JavaScript, so
+    // cooperative handlers should still watch context.signal.
+    Promise.resolve(promise).catch(() => {});
+  }
+}
+
+function abortReason(signal) {
+  return signal.reason ?? new CancellationError('operation aborted');
+}
+
+function wasAbortBecauseJobStopped(job, error) {
+  return job.status === 'cancelled' || job.status === 'timed_out' || error instanceof CancellationError;
+}
+
+function attemptAbortCode(error) {
+  return error?.code === 'ABORT_ERR' || error?.name === 'AbortError';
+}
+
+function normalizeError(error) {
+  if (!error) return null;
+  if (typeof error === 'string') return { name: 'Error', message: error };
+  return {
+    name: error.name ?? 'Error',
+    message: error.message ?? String(error),
+    code: error.code,
+    task: error.task,
+    stack: error.stack,
+    cause: error.cause ? normalizeError(error.cause) : undefined,
+  };
+}
+
+function isTerminal(status) {
+  return TERMINAL_STATUSES.has(status);
+}
+
+function normalizePositiveInteger(value, name) {
+  if (!Number.isInteger(value) || value < 1) throw new TypeError(`${name} must be a positive integer`);
+  return value;
+}
+
+function normalizeNonNegativeInteger(value, name) {
+  if (!Number.isInteger(value) || value < 0) throw new TypeError(`${name} must be a non-negative integer`);
+  return value;
+}
+
+function normalizeFiniteNumber(value, name) {
+  if (typeof value !== 'number' || !Number.isFinite(value)) throw new TypeError(`${name} must be a finite number`);
+  return value;
+}
+
+function normalizeOptionalNonNegativeNumber(value, name) {
+  if (value === undefined || value === null) return undefined;
+  if (typeof value !== 'number' || !Number.isFinite(value) || value < 0) {
+    throw new TypeError(`${name} must be a non-negative finite number`);
+  }
+  return value;
+}
+
+function setManagedTimeout(callback, delayMs) {
+  return setTimeout(callback, delayMs);
+}
+
+function createJobId() {
+  if (typeof cryptoThis()?.randomUUID === 'function') return cryptoThis().randomUUID();
+  return `${Date.now()}-${Math.random().toString(36).slice(2)}`;
+}
+
+function cryptoThis() {
+  return globalThis.crypto;
 }
