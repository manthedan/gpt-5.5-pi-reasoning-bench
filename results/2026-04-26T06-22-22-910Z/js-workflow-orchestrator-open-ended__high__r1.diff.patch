+test('schedules queued jobs by priority without preempting running work', async () => {
+  const o = new WorkflowOrchestrator({ concurrency: 1 });
+  const order = [];
+  o.register('record', async value => { order.push(value); return value; });
+
+  const low = o.submit({ input: 'low', steps: [{ task: 'record' }] }, { priority: 0 });
+  const high = o.submit({ input: 'high', steps: [{ task: 'record' }] }, { priority: 10 });
+  const medium = o.submit({ input: 'medium', steps: [{ task: 'record' }] }, { priority: 5 });
+
+  await o.drain();
+  assert.deepEqual(order, ['high', 'medium', 'low']);
+  assert.equal(o.getJob(high).status, 'succeeded');
+  assert.equal(o.getJob(medium).status, 'succeeded');
+  assert.equal(o.getJob(low).status, 'succeeded');
+});
+
+test('cancels running jobs and frees drain even when a handler ignores the signal', async () => {
+  const o = new WorkflowOrchestrator({ concurrency: 1 });
+  o.register('hang', () => new Promise(() => {}));
+  const id = o.submit({ input: 'x', steps: [{ task: 'hang' }] });
+
+  await new Promise(resolve => o.once('step:started', resolve));
+  assert.equal(o.cancel(id, 'no longer needed'), true);
+  await o.drain({ timeoutMs: 50 });
+
+  const job = o.getJob(id);
+  assert.equal(job.status, 'cancelled');
+  assert.equal(job.reason, 'no longer needed');
+  assert.equal(job.steps[0].attempts[0].status, 'cancelled');
+});
