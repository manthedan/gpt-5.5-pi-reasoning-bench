+test('enforces step timeouts and records timeout errors', async () => {
+  const o = new WorkflowOrchestrator({ concurrency: 1 });
+  o.register('hang', () => new Promise(() => {}));
+  const id = o.submit({ input: 'x', steps: [{ task: 'hang', timeoutMs: 5 }] });
