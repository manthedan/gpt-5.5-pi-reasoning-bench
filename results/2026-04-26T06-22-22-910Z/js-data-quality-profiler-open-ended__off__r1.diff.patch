+test('detects required violations, mixed types, and suspicious dates', () => {
+  const csv = 'id,event_date,qty\n1,1899-12-31,10\n,2026-01-01,eleven\n3,2026-02-01,12\n';
+  const result = profileCsv(csv, { primaryKey: 'id', required: ['id'], dateColumns: ['event_date'] });
+  assert.equal(result.issues.some(i => i.type === 'required_field_missing' && i.column === 'id'), true);
+  assert.equal(result.issues.some(i => i.type === 'mixed_types' && i.column === 'qty'), true);
+  assert.equal(result.issues.some(i => i.type === 'suspicious_date' && i.column === 'event_date'), true);
+  assert.equal(result.columns.event_date.type, 'date');
