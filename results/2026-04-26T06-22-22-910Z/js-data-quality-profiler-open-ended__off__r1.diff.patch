+
+function parseDateStrict(value) {
+  let m = /^(\d{4})-(\d{2})-(\d{2})(?:[T\s](\d{2}):(\d{2})(?::(\d{2})(?:\.\d{1,3})?)?(Z|[+-]\d{2}:?\d{2})?)?$/.exec(value);
+  if (m) {
+    const [, y, mo, d, hh = '00', mm = '00', ss = '00'] = m;
+    const iso = `${y}-${mo}-${d}T${hh}:${mm}:${ss}${m[7] ? (m[7] === 'Z' ? 'Z' : m[7]) : 'Z'}`;
+    const date = new Date(iso);
+    if (date.getUTCFullYear() === +y && date.getUTCMonth() + 1 === +mo && date.getUTCDate() === +d) return date;
+    return null;
+  }
+  m = /^(\d{1,2})\/(\d{1,2})\/(\d{4})$/.exec(value);
+  if (m) {
+    const [, mo, d, y] = m;
+    const date = new Date(Date.UTC(+y, +mo - 1, +d));
+    if (date.getUTCFullYear() === +y && date.getUTCMonth() + 1 === +mo && date.getUTCDate() === +d) return date;
+  }
+  return null;
+}
