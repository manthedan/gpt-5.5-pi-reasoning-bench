+function isDateLikeColumn(name, opts) {
+  if (opts.dateColumns && opts.dateColumns.includes(name)) return true;
+  return /(^|_)(date|dt|time|timestamp|created_at|updated_at|dob)($|_)/i.test(name) || /_at$/i.test(name);
+}
+
+function inferColumnType(counts, nonNulls, wantsDate) {
+  if (!nonNulls) return 'empty';
+  const normalized = { ...counts };
+  if (normalized.integer && normalized.number) {
+    normalized.number += normalized.integer;
+    delete normalized.integer;
+  }
+  if (wantsDate && (normalized.date ?? 0) > 0) return 'date';
+  let best = 'string';
+  let bestCount = -1;
+  for (const [type, count] of Object.entries(normalized)) {
+    if (count > bestCount) { best = type; bestCount = count; }
+  }
+  return best;
+}
+
+function updateMinMax(_stats, _classification) {
+  // Min/max are recomputed after final type inference to avoid mixed-type noise.
+}
+
+function addInvalidExample(stats, value, row, max, reason) {
+  if (stats.invalidExamples.length < max) stats.invalidExamples.push({ row: row.__meta.rowNumber, value, reason });
+}
+
+function addIssueOnce(bucket, column, row, value, observedType) {
+  bucket[column] ??= [];
+  if (bucket[column].length < 10) bucket[column].push({ row: row.__meta.rowNumber, value, observedType });
+}
+
+function detectDuplicateKeys(parsed, keySpec, nullLike, issues, suggestions) {
+  const columns = Array.isArray(keySpec)
+    ? keySpec.map(s => String(s).trim()).filter(Boolean)
+    : String(keySpec).split(',').map(s => s.trim()).filter(Boolean);
+  if (!columns.length || columns.some(c => !parsed.headers.includes(c))) return;
+  const seen = new Map();
+  for (const row of parsed.rows) {
+    const key = columns.map(c => String(row[c] ?? '').trim()).join('\u0001');
+    if (columns.some(c => isNullLike(row[c] ?? '', nullLike))) continue;
+    if (seen.has(key)) {
+      const firstRow = seen.get(key);
+      issues.push({
+        type: 'duplicate_primary_key',
+        severity: 'error',
+        columns,
+        key: key.replaceAll('\u0001', '|'),
+        rows: [firstRow, row.__meta.rowNumber],
+        message: `Duplicate primary key ${key.replaceAll('\u0001', '|')} on rows ${firstRow} and ${row.__meta.rowNumber}.`
+      });
+    } else {
+      seen.set(key, row.__meta.rowNumber);
+    }
+  }
+  if (issues.some(issue => issue.type === 'duplicate_primary_key' && sameColumns(issue.columns, columns))) {
+    suggestions.push({
+      type: 'deduplicate_primary_key',
+      columns,
+      message: `Deduplicate by ${columns.join(', ')} before loading; keep the newest row, merge duplicates, or generate a surrogate key.`
+    });
+  }
+}
+
+function sameColumns(a, b) {
+  return a.length === b.length && a.every((value, index) => value === b[index]);
+}
+
+function isSuspiciousDate(date) {
+  const year = date.getUTCFullYear();
+  const nextYear = new Date().getUTCFullYear() + 1;
+  return year < 1900 || year > nextYear;
+}
+
+function formatTypeCounts(counts) {
+  return Object.entries(counts).map(([type, n]) => `${type}: ${n}`).join(', ');
 }
