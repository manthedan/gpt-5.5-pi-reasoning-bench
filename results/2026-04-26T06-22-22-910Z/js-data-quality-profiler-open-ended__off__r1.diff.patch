+
+function isNullLike(value, nullLike) { return nullLike.has(String(value).trim().toLowerCase()); }
+
+function classifyPrimitive(value, { preferDate = false } = {}) {
+  const trimmed = String(value).trim();
+  if (/^(true|false|yes|no|y|n)$/i.test(trimmed)) return { type: 'boolean', value: /^(true|yes|y)$/i.test(trimmed) };
+  if (/^[+-]?\d+$/.test(trimmed)) return { type: 'integer', value: Number(trimmed) };
+  if (/^[+-]?(?:\d+\.\d+|\d+\.|\.\d+)(?:e[+-]?\d+)?$/i.test(trimmed) || /^[+-]?\d+e[+-]?\d+$/i.test(trimmed)) return { type: 'number', value: Number(trimmed) };
+  const date = parseDateStrict(trimmed);
+  if (date) return { type: 'date', value: date };
+  if (preferDate) return { type: 'string', value: trimmed };
+  if (EMAIL_RE.test(trimmed)) return { type: 'string', semantic: 'email', value: trimmed };
+  return { type: 'string', value: trimmed };
