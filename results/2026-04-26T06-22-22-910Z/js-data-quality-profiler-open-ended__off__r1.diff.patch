+
+function normalizeHeaders(fields, opts) {
+  const seen = new Map();
+  return fields.map((h, i) => {
+    let name = opts.trimHeaders ? String(h).trim() : String(h);
+    if (!name) name = `column_${i + 1}`;
+    const count = seen.get(name) ?? 0;
+    seen.set(name, count + 1);
+    return count ? `${name}_${count + 1}` : name;
+  });
