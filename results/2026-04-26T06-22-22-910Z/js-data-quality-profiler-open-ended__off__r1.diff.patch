+function tokenizeCsv(text, opts) {
+  const records = [];
+  const warnings = [];
+  let fields = [];
+  let field = '';
+  let inQuotes = false;
+  let wasQuoted = false;
+  let atFieldStart = true;
+  let atRecordStart = true;
+  let startLine = 1;
+  let line = 1;
+  let i = 0;
+
+  const pushField = () => {
+    fields.push(wasQuoted || !opts.trimUnquoted ? field : field.trim());
+    field = '';
+    wasQuoted = false;
+    atFieldStart = true;
+    atRecordStart = false;
+  };
+  const pushRecord = () => {
+    pushField();
+    const isBlank = fields.every(f => f === '');
+    if (!(opts.skipBlankLines && isBlank)) records.push({ fields, startLine });
+    fields = [];
+    field = '';
+    wasQuoted = false;
+    atFieldStart = true;
+    atRecordStart = true;
+    startLine = line + 1;
+  };
+
+  while (i < text.length) {
+    const ch = text[i];
+
+    if (!inQuotes && atRecordStart && opts.comments && field === '' && fields.length === 0 && text.startsWith(opts.commentPrefix, i)) {
+      while (i < text.length && text[i] !== '\n' && text[i] !== '\r') i++;
+      continue;
+    }
+
+    if (inQuotes) {
+      if (ch === '"') {
+        if (text[i + 1] === '"') { field += '"'; i += 2; continue; }
+        inQuotes = false; i++; continue;
+      }
+      field += ch;
+      if (ch === '\n') line++;
+      i++;
+      continue;
+    }
+
+    if (ch === '"' && atFieldStart) { inQuotes = true; wasQuoted = true; atFieldStart = false; i++; continue; }
+    if (ch === ',') { pushField(); i++; continue; }
+    if (ch === '\n' || ch === '\r') {
+      if (ch === '\r' && text[i + 1] === '\n') i++;
+      pushRecord();
+      line++;
+      i++;
+      startLine = line;
+      continue;
+    }
+    field += ch;
+    if (!/\s/.test(ch)) { atFieldStart = false; atRecordStart = false; }
+    i++;
+  }
+
+  if (inQuotes) {
+    warnings.push({
+      type: 'unterminated_quote',
+      line: startLine,
+      message: `Quoted field starting on line ${startLine} was not terminated before end of file.`
+    });
+  }
+  if (field.length > 0 || fields.length > 0 || !opts.skipBlankLines) pushRecord();
+  return { records, warnings };
