+export function buildMessageTree(entries) {
+  const byId = new Map();
+  const roots = [];
+  const orphans = [];
+  for (const entry of entries) {
+    if (entry.type !== 'message' || !entry.id) continue;
+    byId.set(entry.id, { entry, id: entry.id, parentId: entry.parentId ?? null, children: [] });
+  }
+  for (const node of byId.values()) {
+    if (node.parentId && byId.has(node.parentId)) byId.get(node.parentId).children.push(node);
+    else {
+      roots.push(node);
+      if (node.parentId) orphans.push(node.id);
+    }
+  }
+  const leaves = [...byId.values()].filter(n => n.children.length === 0);
+  return { byId, roots, leaves, orphans };
+}
+
+export function getActiveBranch(tree) {
+  const latestLeaf = [...tree.leaves].sort((a, b) => timestampMs(getTimestamp(b.entry)) - timestampMs(getTimestamp(a.entry)))[0];
+  if (!latestLeaf) return [];
+  const branch = [];
+  let node = latestLeaf;
+  while (node) {
+    branch.unshift(node.entry);
+    node = node.parentId ? tree.byId.get(node.parentId) : null;
+  }
+  return branch;
 }
 
