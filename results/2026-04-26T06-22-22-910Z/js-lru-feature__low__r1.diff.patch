   set(key, value) {
+    let node = this._items.get(key);
+
+    if (node !== undefined) {
+      node.value = value;
+      this._moveToHead(node);
+      return this;
+    }
+
+    node = { key, value, prev: undefined, next: undefined };
+    this._items.set(key, node);
+    this._addToHead(node);
+
+    if (this._items.size > this.capacity) {
+      this._deleteNode(this._tail);
+    }
+
     return this;
   }
 
   has(key) {
