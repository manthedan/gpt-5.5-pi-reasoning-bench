diff --git a/orchestrator.test.js b/orchestrator.test.js
index 13b3df2..212d513 100644
--- a/orchestrator.test.js
+++ b/orchestrator.test.js
@@ -49,3 +49,77 @@ test('emits structured lifecycle events', async () => {
   assert.equal(events.some(e => e.type === 'job:succeeded' && e.jobId === id), true);
   assert.equal(events.every(e => typeof e.timestamp === 'number'), true);
 });
+
+test('schedules higher-priority queued jobs first', async () => {
+  const o = new WorkflowOrchestrator({ concurrency: 1 });
+  const order = [];
+  o.register('record', async value => { order.push(value); return value; });
+
+  o.submit({ input: 'low', steps: [{ task: 'record' }] }, { priority: 1 });
+  const high = o.submit({ input: 'high', steps: [{ task: 'record' }] }, { priority: 10 });
+  await o.drain();
+
+  assert.deepEqual(order, ['high', 'low']);
+  assert.equal(o.getJob(high).status, 'succeeded');
+});
+
+test('cancels queued jobs without running their handlers', async () => {
+  const o = new WorkflowOrchestrator({ concurrency: 1 });
+  let ranVictim = false;
+  o.register('slow', async value => { await sleep(20); return value; });
+  o.register('victim', async value => { ranVictim = true; return value; });
+
+  o.submit({ input: 'first', steps: [{ task: 'slow' }] });
+  const victim = o.submit({ input: 'second', steps: [{ task: 'victim' }] });
+  assert.equal(o.cancel(victim, 'not needed'), true);
+  await o.drain();
+
+  assert.equal(ranVictim, false);
+  assert.equal(o.getJob(victim).status, 'cancelled');
+  assert.equal(o.getJob(victim).reason, 'not needed');
+});
+
+test('supports cooperative cancellation of running jobs', async () => {
+  const o = new WorkflowOrchestrator({ concurrency: 1 });
+  o.register('wait', async (value, { signal }) => {
+    await new Promise((resolve, reject) => {
+      const timer = setTimeout(resolve, 100);
+      signal.addEventListener('abort', () => {
+        clearTimeout(timer);
+        reject(signal.reason);
+      }, { once: true });
+    });
+    return value;
+  });
+
+  const id = o.submit({ input: 'x', steps: [{ task: 'wait' }] });
+  await sleep(5);
+  assert.equal(o.cancel(id, 'stop'), true);
+  await o.drain();
+
+  const job = o.getJob(id);
+  assert.equal(job.status, 'cancelled');
+  assert.equal(job.steps[0].status, 'cancelled');
+});
+
+test('times out slow steps and records errors', async () => {
+  const o = new WorkflowOrchestrator();
+  o.register('too-slow', async (value, { signal }) => {
+    await new Promise((resolve, reject) => {
+      const timer = setTimeout(resolve, 100);
+      signal.addEventListener('abort', () => {
+        clearTimeout(timer);
+        reject(signal.reason);
+      }, { once: true });
+    });
+    return value;
+  });
+
+  const id = o.submit({ input: 'x', steps: [{ task: 'too-slow', timeoutMs: 5 }] });
+  await o.drain();
+
+  const job = o.getJob(id);
+  assert.equal(job.status, 'timed_out');
+  assert.equal(job.steps[0].status, 'timed_out');
+  assert.equal(job.error.name, 'TimeoutError');
+});
