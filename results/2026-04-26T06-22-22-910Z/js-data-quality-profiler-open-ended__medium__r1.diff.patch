+++ b/profiler.test.js
@@ -28,3 +28,22 @@ test('detects duplicate primary keys and inconsistent row widths with suggestion
   assert.equal(result.suggestions.length > 0, true);
   assert.equal(result.suggestions.every(s => typeof s.message === 'string' && s.message.length > 0), true);
 });
+
+test('handles embedded newlines and keeps source metadata', () => {
+  const csv = 'id,notes\n1,"line one\nline two"\n2,done\n';
+  const parsed = parseCsv(csv);
+  assert.equal(parsed.rows[0].notes, 'line one\nline two');
+  assert.equal(parsed.records[0].line, 2);
+  assert.equal(parsed.records[1].line, 4);
+});
+
+test('reports required fields, suspicious dates, and composite primary keys', () => {
+  const csv = 'tenant,id,birth_date,score\na,1,1880-01-01,10\na,1,2020-02-30,high\nb,,2026-01-01,11\n';
+  const result = profileCsv(csv, { required: ['tenant', 'id'], primaryKey: ['tenant', 'id'] });
+  assert.equal(result.issues.some(i => i.type === 'required_field_missing' && i.column === 'id'), true);
+  assert.equal(result.issues.some(i => i.type === 'primary_key_missing'), true);
+  assert.equal(result.issues.some(i => i.type === 'duplicate_primary_key'), true);
+  assert.equal(result.issues.some(i => i.type === 'suspicious_date'), true);
+  assert.equal(result.issues.some(i => i.type === 'invalid_date' && i.value === '2020-02-30'), true);
+  assert.equal(result.issues.some(i => i.type === 'mixed_types' && i.column === 'score'), true);
