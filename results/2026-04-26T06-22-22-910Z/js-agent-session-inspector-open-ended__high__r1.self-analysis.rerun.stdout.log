try?.toolName, entry?.name),\n    isError: Boolean(message?.isError ?? message?.is_error ?? entry?.isError ?? entry?.error),\n    raw: message\n  };\n}\n\nfunction isErrorEntry(entry, message) {\n  if (entry?.type === 'error') return true;\n  if (entry?.level === 'error' || entry?.severity === 'error') return true;\n  if (message?.role === 'error') return true;\n  if (message?.error && normalizeRole(message?.role) !== ROLE_TOOL_RESULT) return true;\n  return false;\n}\n\nfunction describeErrorEntry(entry, message) {\n  const text = firstString(entry?.message, message?.message, entry?.error?.message, message?.error?.message, entry?.type);\n  return text ? `Error entry: ${text}` : 'Error entry encountered';\n}\n\nfunction increment(object, key) {\n  const safeKey = key || 'unknown';\n  object[safeKey] = (object[safeKey] ?? 0) + 1;\n}\n\nfunction inferFileTouchesFromToolCall(call) {\n  const name = (call.name ?? '').toLowerCase();\n  const operation = operationForTool(name);\n  const paths = new Set();\n  collectPaths(call.arguments, paths);\n\n  const command = firstString(call.arguments?.command, call.arguments?.cmd, call.arguments?.value);\n  if (name.includes('bash') || name.includes('shell') || command) {\n    for (const path of inferPathsFromCommand(command ?? '')) paths.add(path);\n  }\n\n  return [...paths].map(path => ({ path, operation }));\n}\n\nfunction operationForTool(name) {\n  if (/delete|remove|rm/.test(name)) return 'delete';\n  if (/move|rename|mv/.test(name)) return 'move';\n  if (/write|create|save/.test(name)) return 'write';\n  if (/edit|patch|replace|apply/.test(name)) return 'edit';\n  if (/grep|search|find|rg|glob|ls|list/.test(name)) return 'search';\n  if (/read|cat|open|view/.test(name)) return 'read';\n  if (/bash|shell|exec|command/.test(name)) return 'command';\n  return 'unknown';\n}\n\nfunction collectPaths(value, paths, key = '', depth = 0) {\n  if (depth > 4 || value === null || value === undefined) return;\n  if (typeof value === 's