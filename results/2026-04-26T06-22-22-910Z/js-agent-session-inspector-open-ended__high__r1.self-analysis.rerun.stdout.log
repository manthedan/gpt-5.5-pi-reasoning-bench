              "newText": "/**\n * Convenience helper for callers that want parse + analyze in one step while\n * still receiving both the raw parse diagnostics and structured analysis.\n *\n * @param {string|Buffer} text\n * @param {{ parse?: object, analysis?: object, report?: object }} [options]\n */\nexport function inspectSessionJsonl(text, options = {}) {\n  const parsed = parseSessionJsonl(text, options.parse ?? {});\n  const analysis = analyzeSession(parsed, options.analysis ?? {});\n  return {\n    parsed,\n    analysis,\n    report: formatReport(analysis, options.report ?? {})\n  };\n}\n\n/**\n * Format a concise human-readable session report.\n *\n * @param {ReturnType<typeof analyzeSession>} analysis\n * @param {{ maxAnomalies?: number, maxFiles?: number }} [options]\n */\nexport function formatReport(analysis, options = {}) {"
