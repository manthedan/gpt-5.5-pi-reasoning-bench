          "edits": [
            {
              "oldText": "test('formats a human-readable report with anomalies', () => {\n  const parsed = parseSessionJsonl(fixture);\n  const report = formatReport(analyzeSession(parsed.entries, parsed.diagnostics));\n  assert.match(report, /assistant turns/i);\n  assert.match(report, /tokens/i);\n  assert.match(report, /malformed/i);\n});\n",
              "newText": "test('formats a human-readable report with anomalies', () => {\n  const parsed = parseSessionJsonl(fixture);\n  const report = formatReport(analyzeSession(parsed.entries, parsed.diagnostics));\n  assert.match(report, /assistant turns/i);\n  assert.match(report, /tokens/i);\n  assert.match(report, /malformed/i);\n});\n\ntest('reconstructs branches and chooses the latest active leaf', () => {\n  const entries = [\n    { type: 'message', id: 'root', parentId: null, timestamp: '2026-01-01T00:00:00.000Z', message: { role: 'user' } },\n    { type: 'message', id: 'old', parentId: 'root', timestamp: '2026-01-01T00:00:01.000Z', message: { role: 'assistant' } },\n    { type: 'message', id: 'new', parentId: 'root', timestamp: '2026-01-01T00:00:02.000Z', message: { role: 'assistant' } }\n  ];\n\n  const analysis = analyzeSession(entries);\n  assert.equal(analysis.tree.branchCount, 1);\n  assert.deepEqual(analysis.tree.activePathIds, ['root', 'new']);\n  assert.match(formatReport(analysis), /branched conversation history/i);\n});\n\ntest('infers file touches and tool anomalies from common variants', () => {\n  const parsed = parseSessionJsonl([\n    JSON.stringify({ type: 'message', id: 'a', timestamp: 1767225600, message: { role: 'assistant', tool_calls: [{ id: 'call-1', function: { name: 'write', arguments: '{\"path\":\"src/app.js\"}' } }] } }),\n    JSON.stringify({ type: 'message', id: 't', parentId: 'a', timestamp: 1767225601, message: { role: 'tool', tool_call_id: 'call-1', is_error: true } })\n  ].join('\\n'));\n\n  const analysis = analyzeSession(parsed);\n  assert.equal(analysis.metrics.toolCalls.write, 1);\n  assert.equal(analysis.metrics.toolErrors, 1);\n  assert.deepEqual(analysis.metrics.filesTouched, ['src/app.js']);\n  assert.equal(analysis.metrics.fileTouchDetails['src/app.js'].operations[0], 'write');\n});\n"
            }
          ]
        },
