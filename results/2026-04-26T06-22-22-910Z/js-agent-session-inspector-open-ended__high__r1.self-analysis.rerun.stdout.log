              "text": "diff --git a/session-inspector.js b/session-inspector.js\nindex 09b89d5..bcbfb02 100644\n--- a/session-inspector.js\n+++ b/session-inspector.js\n@@ -1,19 +1,839 @@\n-export function parseSessionJsonl(text) {\n-  return text.trim().split('\\n').map(line => JSON.parse(line));\n+const ROLE_ASSISTANT = 'assistant';\n+const ROLE_USER = 'user';\n+const ROLE_TOOL_RESULT = 'toolResult';\n+\n+/**\n+ * Parse a Pi-style JSONL session.\n+ *\n+ * The parser is deliberately forgiving: malformed records are skipped and\n+ * reported with line numbers, while valid lines are returned unchanged. Blank\n+ * lines are ignored by default because real logs often end with a newline or\n+ * contain occasional spacing from manual edits.\n+ *\n+ * @param {string|Buffer} text JSONL text\n+ * @param {{ includeBlankDiagnostics?: boolean }} [options]\n+ * @returns {{ entries: any[], diagnostics: Array<object>, lineMap: Array<object> }}\n+ */\n+export function parseSessionJsonl(text, options = {}) {\n+  const source = Buffer.isBuffer(text) ? text.toString('utf8') : String(text ?? '');\n+  const lines = source.split(/\\r?\\n/);\n+  const entries = [];\n+  const diagnostics = [];\n+  const lineMap = [];\n+\n+  for (let index = 0; index < lines.length; index += 1) {\n+    const line = lines[index];\n+    const lineNumber = index + 1;\n+\n+    // Ignore the final empty line from a trailing newline, and by default all\n+    // blank lines. Keep an opt-in diagnostic for callers that need strict JSONL.\n+    if (line.trim() === '') {\n+      if (options.includeBlankDiagnostics && !(index === lines.length - 1 && line === '')) {\n+        diagnostics.push({\n+          type: 'blank-line',\n+          severity: 'info',\n+          line: lineNumber,\n+          message: 'Blank line ignored',\n+          raw: line\n+        });\n+      }\n+      lineMap.push({ line: lineNumber, raw: line, skipped: true });\n+      continue;\n+    }\n+\n+    try {\n+      const entry = JSON.parse(line);\n+      entries.push(entry);\n+      lineMap.push({ line: lineNumber, raw: line, entry });\n+    } catch (error) {\n+      diagnostics.push({\n+        type: 'malformed-json',\n+        severity: 'error',\n+        line: lineNumber,\n+        column: extractJsonErrorColumn(error),\n+        message: error instanceof Error ? error.message : String(error),\n+        raw: line\n+      });\n+      lineMap.push({ line: lineNumber, raw: line, error });\n+    }\n+  }\n+\n+  return { entries, diagnostics, lineMap };\n }\n \n-export function analyzeSession(entries) {\n+/**\n+ * Analyze parsed session entries and derive branch/tree, metrics and anomalies.\n+ *\n+ * Accepts either an array of entries or the full object returned by\n+ * parseSessionJsonl(). Diagnostics may be passed separately for backwards- and\n+ * test-friendly usage.\n+ *\n+ * @param {any[]|{ entries: any[], diagnostics?: Array<object> }} entriesOrParsed\n+ * @param {Array<object>} [diagnostics]\n+ * @param {{ activeLeafId?: string }} [options]\n+ */\n+export function analyzeSession(entriesOrParsed, diagnostics = [], options = {}) {\n+  const diagnosticsAreArray = Array.isArray(diagnostics);\n+  const analysisOptions = diagnosticsAreArray ? options : diagnostics;\n+  const parsedInput = Array.isArray(entriesOrParsed)\n+    ? { entries: entriesOrParsed, diagnostics: diagnosticsAreArray ? diagnostics : [] }\n+    : { entries: entriesOrParsed?.entries ?? [], diagnostics: entriesOrParsed?.diagnostics ?? (diagnosticsAreArray ? diagnostics : []) };\n+\n+  const entries = parsedInput.entries;\n+  const parseDiagnostics = Array.isArray(parsedInput.diagnostics) ? parsedInput.diagnostics : [];\n+  const anomalies = parseDiagnostics.map(diagnostic => ({\n+    type: diagnostic.type ?? 'diagnostic',\n+    severity: diagnostic.severity ?? 'warning',\n+    line: diagnostic.line,\n+    message: diagnostic.message ?? String(diagnostic),\n+    diagnostic\n+  }));\n+\n+  const session = extractSessionInfo(entries);\n+  const tree = buildMessageTree(entries, anomalies, analysisOptions);\n+  const metrics = computeMetrics(entries, tree, parseDiagnostics, anomalies);\n+  const signals = computeSignals(metrics, tree, anomalies);\n+\n   return {\n     entries,\n-    metrics: {\n-      assistantTurns: 0,\n-      totalTokens: 0,\n-      cost: 0,\n-      toolCalls: {}\n+    diagnostics: parseDiagnostics,\n+    session,\n+    tree,\n+    metrics,\n+    anomalies,\n+    signals\n+  };\n+}\n+\n+/**\n+ * Convenience helper for callers that want parse + analyze in one step while\n+ * still receiving both the raw parse diagnostics and structured analysis.\n+ *\n+ * @param {string|Buffer} text\n+ * @param {{ parse?: object, analysis?: object, report?: object }} [options]\n+ */\n+export function inspectSessionJsonl(text, options = {}) {\n+  const parsed = parseSessionJsonl(text, options.parse ?? {});\n+  const analysis = analyzeSession(parsed, options.analysis ?? {});\n+  return {\n+    parsed,\n+    analysis,\n+    report: formatReport(analysis, options.report ?? {})\n+  };\n+}\n+\n+/**\n+ * Format a concise human-readable session report.\n+ *\n+ * @param {ReturnType<typeof analyzeSession>} analysis\n+ * @param {{ maxAnomalies?: number, maxFiles?: number }} [options]\n+ */\n+export function formatReport(analysis, options = {}) {\n+  const maxAnomalies = options.maxAnomalies ?? 8;\n+  const maxFiles = options.maxFiles ?? 10;\n+  const metrics = analysis?.metrics ?? {};\n+  const tree = analysis?.tree ?? {};\n+  const session = analysis?.session ?? {};\n+  const anomalies = analysis?.anomalies ?? [];\n+  const signals = analysis?.signals ?? [];\n+\n+  const lines = [];\n+  lines.push('Session report');\n+\n+  const sessionParts = [];\n+  if (session.id) sessionParts.push(`id ${session.id}`);\n+  if (session.cwd) sessionParts.push(`cwd ${session.cwd}`);\n+  if (session.version !== undefined) sessionParts.push(`version ${session.version}`);\n+  if (sessionParts.length > 0) lines.push(`- Session: ${sessionParts.join('; ')}`);\n+\n+  lines.push(`- Time range: ${formatTimeRange(metrics.startTime, metrics.endTime, metrics.durationMs)}`);\n+  lines.push(\n+    `- Messages: ${metrics.userTurns ?? 0} user, ${metrics.assistantTurns ?? 0} assistant turns, ` +\n+    `${metrics.toolResults ?? 0} tool results (${metrics.activeBranchMessages ?? 0} messages on active branch)`\n+  );\n+  lines.push(\n+    `- Branching: ${tree.nodeCount ?? 0} message nodes, ${tree.leafCount ?? 0} leaves, ` +\n+    `${tree.branchCount ?? 0} branch points, max depth ${tree.maxDepth ?? 0}`\n+  );\n+\n+  const tokens = metrics.tokens ?? {};\n+  lines.push(\n+    `- Usage: ${formatNumber(metrics.totalTokens ?? tokens.total ?? 0)} tokens` +\n+    ` (in ${formatNumber(tokens.input ?? 0)}, out ${formatNumber(tokens.output ?? 0)}, cache ${formatNumber((tokens.cacheRead ?? 0) + (tokens.cacheWrite ?? 0))}); ` +\n+    `cost ${formatCurrency(metrics.cost ?? 0)}`\n+  );\n+\n+  lines.push(`- Tools: ${formatToolCalls(metrics.toolCalls)}; ${metrics.toolErrors ?? 0} tool errors; ${metrics.pendingToolCalls ?? 0} pending results`);\n+\n+  const files = metrics.filesTouched ?? [];\n+  if (files.length > 0) {\n+    const rendered = files.slice(0, maxFiles).map(file => {\n+      const detail = metrics.fileTouchDetails?.[file];\n+      const ops = detail?.operations?.length ? ` (${detail.operations.join('/')})` : '';\n+      return `${file}${ops}`;\n+    });\n+    const suffix = files.length > maxFiles ? `, +${files.length - maxFiles} more` : '';\n+    lines.push(`- Files touched: ${rendered.join(', ')}${suffix}`);\n+  } else {\n+    lines.push('- Files touched: none inferred');\n+  }\n+\n+  if (signals.length > 0) lines.push(`- Productivity signals: ${signals.join('; ')}`);\n+\n+  if (anomalies.length > 0) {\n+    lines.push(`- Anomalies (${anomalies.length}):`);\n+    for (const anomaly of anomalies.slice(0, maxAnomalies)) {\n+      const location = anomaly.line ? `line ${anomaly.line}: ` : '';\n+      const label = anomaly.type ? `${humanizeAnomalyType(anomaly.type)}: ` : '';\n+      lines.push(`  • ${location}${label}${anomaly.message}`);\n+    }\n+    if (anomalies.length > maxAnomalies) lines.push(`  • … ${anomalies.length - maxAnomalies} more`);\n+  } else {\n+    lines.push('- Anomalies: none detected');\n+  }\n+\n+  return `${lines.join('\\n')}\\n`;\n+}\n+\n+export function buildMessageTree(entries, anomalies = [], options = {}) {\n+  const nodes = [];\n+  const idToNode = new Map();\n+  const duplicateCounts = new Map();\n+\n+  entries.forEach((entry, order) => {\n+    if (!isMessageEntry(entry)) return;\n+\n+    const message = getMessage(entry);\n+    const originalId = firstString(entry.id, message.id, entry.messageId, message.messageId);\n+    const id = originalId ?? `__message_${order + 1}`;\n+    const duplicateNumber = duplicateCounts.get(id) ?? 0;\n+    duplicateCounts.set(id, duplicateNumber + 1);\n+\n+    if (duplicateNumber > 0) {\n+      anomalies.push({\n+        type: 'duplicate-id',\n+        severity: 'warning',\n+        message: `Duplicate message id \"${id}\" encountered; keeping both nodes but parent links target the first occurrence`,\n+        entry\n+      });\n+    }\n+\n+    if (!originalId) {\n+      anomalies.push({\n+        type: 'missing-id',\n+        severity: 'warning',\n+        message: `Message at entry ${order + 1} has no id; generated ${id}`,\n+        entry\n+      });\n+    }\n+\n+    const node = {\n+      key: duplicateNumber > 0 ? `${id}#${duplicateNumber + 1}` : id,\n+      id,\n+      parentId: normalizeParentId(entry.parentId ?? message.parentId ?? entry.parent_id ?? message.parent_id),\n+      entry,\n+      message,\n+      role: normalizeRole(message.role ?? entry.role ?? entry.type),\n+      timestampMs: extractTimestampMs(entry, message),\n+      order,\n+      children: [],\n+      parent: null,\n+      depth: 0\n+    };\n+\n+    nodes.push(node);\n+    if (!idToNode.has(id)) idToNode.set(id, node);\n+  });\n+\n+  for (const node of nodes) {\n+    if (!node.parentId) continue;\n+    const parent = idToNode.get(node.parentId);\n+    if (!parent) {\n+      anomalies.push({\n+        type: 'orphan-node',\n+        severity: 'warning',\n+        message: `Message ${node.id} references missing parent ${node.parentId}`,\n+        entry: node.entry\n+      });\n+      continue;\n     }\n+    node.parent = parent;\n+    parent.children.push(node);\n+  }\n+\n+  for (const node of nodes) {\n+    node.children.sort(compareNodesChronologically);\n+  }\n+\n+  const roots = nodes.filter(node => !node.parent);\n+  for (const root of roots) assignDepths(root, 0, new Set(), anomalies);\n+\n+  const leaves = nodes.filter(node => node.children.length === 0);\n+  const branchPoints = nodes.filter(node => node.children.length > 1);\n+  const requestedActiveId = options.activeLeafId ?? findSessionActiveLeafId(entries);\n+  const activeLeaf = requestedActiveId ? (idToNode.get(requestedActiveId) ?? null) : chooseLatestLeaf(leaves);\n+  const activePath = activeLeaf ? pathToRoot(activeLeaf) : [];\n+\n+  if (requestedActiveId && !activeLeaf) {\n+    anomalies.push({\n+      type: 'missing-active-leaf',\n+      severity: 'warning',\n+      message: `Requested active leaf ${requestedActiveId} was not found in the message tree`\n+    });\n+  }\n+\n+  return {\n+    nodes,\n+    roots,\n+    leaves,\n+    branchPoints,\n+    activeLeaf,\n+    activePath,\n+    activePathIds: activePath.map(node => node.id),\n+    nodeCount: nodes.length,\n+    leafCount: leaves.length,\n+    branchCount: branchPoints.length,\n+    maxDepth: nodes.reduce((max, node) => Math.max(max, node.depth), 0),\n+    byId: idToNode\n+  };\n+}\n+\n+function computeMetrics(entries, tree, parseDiagnostics, anomalies) {\n+  const metrics = {\n+    entryCount: entries.length,\n+    messageCount: tree.nodeCount,\n+    activeBranchMessages: tree.activePath?.length ?? 0,\n+    userTurns: 0,\n+    assistantTurns: 0,\n+    toolResults: 0,\n+    toolCallCount: 0,\n+    toolCalls: {},\n+    toolCallsByName: {},\n+    toolErrors: 0,\n+    pendingToolCalls: 0,\n+    unmatchedToolResults: 0,\n+    errorCount: 0,\n+    parseErrorCount: parseDiagnostics.filter(d => (d.severity ?? 'error') === 'error').length,\n+    tokens: { input: 0, output: 0, cacheRead: 0, cacheWrite: 0, total: 0 },\n+    totalTokens: 0,\n+    cost: 0,\n+    startTime: null,\n+    endTime: null,\n+    durationMs: 0,\n+    toolCallsDetailed: [],\n+    toolResultsDetailed: [],\n+    filesTouched: [],\n+    fileTouchDetails: {}\n   };\n+\n+  const toolCallIds = new Map();\n+  const completedToolCallIds = new Set();\n+  const messageTimes = [];\n+  const allTimes = [];\n+  const fileTouches = new Map();\n+\n+  for (const entry of entries) {\n+    const message = getMessage(entry);\n+    const timestamp = extractTimestampMs(entry, message);\n+    if (timestamp !== null) {\n+      allTimes.push(timestamp);\n+      if (isMessageEntry(entry)) messageTimes.push(timestamp);\n+    }\n+\n+    if (isErrorEntry(entry, message)) {\n+      metrics.errorCount += 1;\n+      anomalies.push({\n+        type: 'error-entry',\n+        severity: 'error',\n+        message: describeErrorEntry(entry, message),\n+        entry\n+      });\n+    }\n+\n+    if (!isMessageEntry(entry)) continue;\n+\n+    const role = normalizeRole(message.role ?? entry.role ?? entry.type);\n+    if (role === ROLE_USER) metrics.userTurns += 1;\n+    if (role === ROLE_ASSISTANT) metrics.assistantTurns += 1;\n+    if (role === ROLE_TOOL_RESULT) metrics.toolResults += 1;\n+\n+    const usage = extractUsage(entry, message);\n+    if (usage) addUsage(metrics, usage);\n+\n+    const calls = extractToolCalls(message, entry);\n+    for (const call of calls) {\n+      metrics.toolCallCount += 1;\n+      increment(metrics.toolCalls, call.name);\n+      increment(metrics.toolCallsByName, call.name);\n+      metrics.toolCallsDetailed.push(call);\n+      if (call.id) toolCallIds.set(call.id, call);\n+     