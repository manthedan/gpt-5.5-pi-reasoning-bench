+  const lines = nonBlankLines(markdown);
+  if (lines.length < 2) {
+    throw new SyntaxError('Markdown table must include a header and separator row');
+  }
+
+  const headers = splitTableRow(lines[0]);
+  const separators = splitTableRow(lines[1]);
+
+  if (
+    headers.length === 0 ||
+    headers.some(header => header === '') ||
+    separators.length !== headers.length ||
+    !separators.every(isSeparatorCell)
+  ) {
+    throw new SyntaxError('Malformed markdown table');
+  }
+
   return lines.slice(2).map(line => {
-    const cells = line.split('|').map(s => s.trim()).filter(Boolean);
-    return Object.fromEntries(headers.map((header, i) => [header, cells[i] ?? '']));
