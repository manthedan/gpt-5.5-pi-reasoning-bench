+export function getActivePath(tree) {
+  const candidates = [...tree.nodes.values()].filter(n => n.entry?.id);
+  const leaves = candidates.filter(n => n.children.length === 0);
+  const leaf = leaves.sort((a, b) => compareTime(b.entry, a.entry) || b.index - a.index)[0];
+  if (!leaf) return [];
+  const path = [];
+  for (let n = leaf; n; n = n.parent) path.unshift(n);
+  return path;
+}
