+export function buildSessionTree(entries) {
+  const nodes = new Map();
+  const roots = [];
+  const orphans = [];
+  const duplicateIds = [];
+  entries.forEach((entry, index) => {
+    const id = entry?.id ?? `__line_${entry?._line ?? index}`;
+    if (nodes.has(id)) duplicateIds.push(id);
+    nodes.set(id, { id, entry, index, parent: null, children: [] });
+  });
+  for (const node of nodes.values()) {
+    const parentId = node.entry?.parentId;
+    if (parentId == null) roots.push(node);
+    else if (nodes.has(parentId)) {
+      node.parent = nodes.get(parentId);
+      node.parent.children.push(node);
+    } else {
+      roots.push(node);
+      orphans.push(node);
+    }
+  }
+  return { nodes, roots, orphans, duplicateIds };
 }
