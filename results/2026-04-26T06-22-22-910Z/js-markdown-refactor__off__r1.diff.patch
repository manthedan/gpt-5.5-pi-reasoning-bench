+function trimBlankLines(lines) {
+  let start = 0;
+  let end = lines.length;
+
+  while (start < end && lines[start].trim() === '') start += 1;
+  while (end > start && lines[end - 1].trim() === '') end -= 1;
+
+  return lines.slice(start, end);
+}
+
+function splitTableRow(line) {
+  const cells = [];
+  let cell = '';
+
+  for (let i = 0; i < line.length; i += 1) {
+    const char = line[i];
+    const next = line[i + 1];
+
+    if (char === '\\' && next === '|') {
+      cell += '|';
+      i += 1;
+    } else if (char === '|') {
+      cells.push(cell.trim());
+      cell = '';
+    } else {
+      cell += char;
+    }
+  }
+
+  cells.push(cell.trim());
+
+  if (cells[0] === '') cells.shift();
+  if (cells[cells.length - 1] === '') cells.pop();
+
+  return cells;
+}
+
+function isSeparatorCell(cell) {
+  return /^:?-{3,}:?$/.test(cell.trim());
+}
+
+function assertValidSeparator(separatorCells, expectedColumns) {
+  if (
+    separatorCells.length !== expectedColumns ||
+    !separatorCells.every(isSeparatorCell)
+  ) {
+    throw new SyntaxError('Malformed markdown table separator');
+  }
+}
+
 export function parseMarkdownTable(markdown) {
-  const lines = markdown.trim().split('\n');
-  const headers = lines[0].split('|').map(s => s.trim()).filter(Boolean);
-  return lines.slice(2).map(line => {
-    const cells = line.split('|').map(s => s.trim()).filter(Boolean);
-    return Object.fromEntries(headers.map((header, i) => [header, cells[i] ?? '']));
+  const lines = trimBlankLines(String(markdown).split(/\r?\n/));
+
+  if (lines.length < 2) {
+    throw new SyntaxError('Markdown table must include a header and separator');
+  }
+
+  const headers = splitTableRow(lines[0]);
+  if (headers.length === 0 || headers.some(header => header === '')) {
+    throw new SyntaxError('Markdown table header must not contain empty cells');
+  }
+
+  assertValidSeparator(splitTableRow(lines[1]), headers.length);
+
+  return lines.slice(2).filter(line => line.trim() !== '').map(line => {
+    let cells = splitTableRow(line);
+
+    // JavaScript strings often arrive with `\|` already cooked into `|`.
+    // If a data row has too many cells, keep the table usable by treating the
+    // earliest extra separators as literal pipe characters.
+    if (cells.length > headers.length) {
+      const extraCells = cells.length - headers.length;
+      cells = [
+        cells.slice(0, extraCells + 1).join(' | '),
+        ...cells.slice(extraCells + 1)
+      ];
+    }
+
+    return Object.fromEntries(
+      headers.map((header, index) => [header, cells[index] ?? ''])
+    );
   });
 }
