+      retryBackoff: options.retryBackoff ?? 2,
+      timeoutMs: options.timeoutMs,
+      stepTimeoutMs: options.stepTimeoutMs,
+    };
     this.handlers = new Map();
     this.jobs = new Map();
+    this._sequence = 0;
+    this._idCounter = 0;
+    this._running = 0;
+    this._drainers = [];
   }
 
   register(name, handler) {
+    if (!name || typeof name !== 'string') throw new TypeError('task name must be a non-empty string');
+    if (typeof handler !== 'function') throw new TypeError('handler must be a function');
     this.handlers.set(name, handler);
     return this;
   }
 
   submit(workflow, options = {}) {
-    const id = options.id ?? String(Date.now());
-    const job = { id, workflow, options, status: 'queued' };
+    if (!workflow || !Array.isArray(workflow.steps)) {
+      throw new TypeError('workflow must contain a steps array');
+    }
+    if (this.jobs.has(options.id)) throw new Error(`job id already exists: ${options.id}`);
+
+    const id = options.id ?? `job-${++this._idCounter}`;
+    if (this.jobs.has(id)) throw new Error(`job id already exists: ${id}`);
+
+    const createdAt = now();
+    const steps = workflow.steps.map((step, index) => {
+      if (!step || typeof step.task !== 'string') throw new TypeError(`step ${index} must specify a task`);
+      return {
+        index,
+        task: step.task,
+        name: step.name,
+        input: step.input,
+        hasInput: Object.hasOwn(step, 'input'),
+        retries: step.retries,
