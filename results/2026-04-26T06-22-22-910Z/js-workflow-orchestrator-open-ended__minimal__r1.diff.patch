 import { EventEmitter } from 'node:events';
 
+const TERMINAL_STATUSES = new Set(['succeeded', 'failed', 'cancelled']);
+const sleep = ms => new Promise(resolve => setTimeout(resolve, ms));
+
+function now() {
+  return Date.now();
+}
+
+function toErrorRecord(error) {
+  if (!error) return undefined;
+  return {
+    name: error.name ?? 'Error',
+    message: error.message ?? String(error),
+    stack: error.stack,
+    code: error.code,
+  };
+}
+
+function ensurePositiveInteger(value, fallback, name) {
+  const resolved = value ?? fallback;
+  if (!Number.isInteger(resolved) || resolved < 1) {
+    throw new TypeError(`${name} must be a positive integer`);
+  }
+  return resolved;
+}
+
+function normalizeTimeout(value, fallback, name) {
+  const resolved = value ?? fallback;
+  if (resolved == null) return undefined;
+  if (!Number.isFinite(resolved) || resolved <= 0) {
+    throw new TypeError(`${name} must be a positive number of milliseconds`);
+  }
+  return resolved;
+}
+
+function createTimeoutError(ms) {
+  const error = new Error(`Timed out after ${ms}ms`);
+  error.name = 'TimeoutError';
+  error.code = 'ETIMEDOUT';
+  return error;
+}
+
+async function runWithTimeout(fn, timeoutMs, signal) {
+  if (signal?.aborted) throw signal.reason ?? new Error('cancelled');
+
+  let timer;
+  let abortListener;
+  const racers = [Promise.resolve().then(fn)];
+
+  if (timeoutMs != null) {
+    racers.push(new Promise((_, reject) => {
+      timer = setTimeout(() => reject(createTimeoutError(timeoutMs)), timeoutMs);
+    }));
+  }
+
+  if (signal) {
+    racers.push(new Promise((_, reject) => {
+      abortListener = () => reject(signal.reason ?? new Error('cancelled'));
+      signal.addEventListener('abort', abortListener, { once: true });
+    }));
+  }
+
+  try {
+    return await Promise.race(racers);
+  } finally {
+    clearTimeout(timer);
+    if (signal && abortListener) signal.removeEventListener('abort', abortListener);
+  }
+}
+
 export class WorkflowOrchestrator extends EventEmitter {
   constructor(options = {}) {
     super();
-    this.options = options;
+    this.options = {
