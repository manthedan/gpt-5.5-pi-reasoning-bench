index 13b3df2..771da1d 100644
--- a/orchestrator.test.js
+++ b/orchestrator.test.js
@@ -49,3 +49,65 @@ test('emits structured lifecycle events', async () => {
   assert.equal(events.some(e => e.type === 'job:succeeded' && e.jobId === id), true);
   assert.equal(events.every(e => typeof e.timestamp === 'number'), true);
 });
+
+test('runs queued jobs by priority without exceeding concurrency', async () => {
+  const o = new WorkflowOrchestrator({ concurrency: 1 });
+  const order = [];
+  o.register('record', async value => { order.push(value); return value; });
+
+  o.submit({ input: 'low', steps: [{ task: 'record' }] }, { priority: 0 });
+  o.submit({ input: 'high', steps: [{ task: 'record' }] }, { priority: 10 });
+  o.submit({ input: 'middle', steps: [{ task: 'record' }] }, { priority: 5 });
+
+  await o.drain();
+  assert.deepEqual(order, ['high', 'middle', 'low']);
+});
+
+test('cancels queued and running jobs and exposes abort signals', async () => {
+  const o = new WorkflowOrchestrator({ concurrency: 1 });
+  o.register('wait', async (_value, { signal }) => {
+    await new Promise((resolve, reject) => {
+      signal.addEventListener('abort', () => reject(signal.reason), { once: true });
+    });
+  });
+
+  const running = o.submit({ steps: [{ task: 'wait' }] });
+  const queued = o.submit({ steps: [{ task: 'wait' }] });
+  await sleep(1);
+
+  assert.equal(o.cancel(queued, 'not needed'), true);
+  assert.equal(o.cancel(running, 'stop now'), true);
+  await o.drain();
+
+  assert.equal(o.getJob(queued).status, 'cancelled');
+  assert.equal(o.getJob(running).status, 'cancelled');
+  assert.equal(o.getJob(running).steps[0].attempts[0].status, 'cancelled');
+});
+
+test('times out slow steps and retries step timeouts', async () => {
+  const o = new WorkflowOrchestrator({ retryDelayMs: 1 });
+  let calls = 0;
+  o.register('eventually-fast', async value => {
+    calls += 1;
+    if (calls === 1) await sleep(20);
+    return value;
+  });
+
+  const id = o.submit({ input: 'ok', steps: [{ task: 'eventually-fast', timeoutMs: 5, retries: 1 }] });
+  await o.drain();
+
+  const job = o.getJob(id);
+  assert.equal(job.status, 'succeeded');
+  assert.equal(calls, 2);
+  assert.equal(job.steps[0].attempts[0].status, 'timed_out');
+});
+
