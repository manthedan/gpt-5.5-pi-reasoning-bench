+  const actual = value ?? fallback;
+  if (!Number.isInteger(actual) || actual < 0) throw new TypeError('Expected a non-negative integer');
+  return actual;
+}
+
+function positiveNumber(value, fallback) {
+  const actual = value ?? fallback;
+  if (typeof actual !== 'number' || !Number.isFinite(actual) || actual <= 0) throw new TypeError('Expected a positive number');
+  return actual;
+}
+
+function nonNegativeNumber(value, fallback) {
+  const actual = value ?? fallback;
+  if (actual === Infinity) return actual;
+  if (typeof actual !== 'number' || !Number.isFinite(actual) || actual < 0) throw new TypeError('Expected a non-negative number');
+  return actual;
+}
+
