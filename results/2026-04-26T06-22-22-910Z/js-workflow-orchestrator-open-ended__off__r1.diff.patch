+  return error?.code === 'CANCELLED' || error?.name === 'AbortError' || error?.name === 'CancellationError';
+}
+
+function isTimeout(error) {
+  return error?.code === 'TIMEOUT' || error?.name === 'TimeoutError';
+}
+
+function isNonEmptyString(value) {
+  return typeof value === 'string' && value.trim().length > 0;
+}
+
+function positiveInteger(value, fallback) {
+  const actual = value ?? fallback;
+  if (!Number.isInteger(actual) || actual <= 0) throw new TypeError('Expected a positive integer');
+  return actual;
+}
+
