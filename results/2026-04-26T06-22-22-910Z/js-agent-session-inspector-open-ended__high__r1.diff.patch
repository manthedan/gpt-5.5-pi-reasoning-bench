+function extractTimestampMs(entry, message = getMessage(entry)) {
+  const candidates = [
+    entry?.timestamp,
+    entry?.createdAt,
+    entry?.time,
+    message?.timestamp,
+    message?.createdAt,
+    message?.time
+  ];
+  for (const candidate of candidates) {
+    const parsed = parseTimestamp(candidate);
+    if (parsed !== null) return parsed;
+  }
+  return null;
