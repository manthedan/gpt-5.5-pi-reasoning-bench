+
+function normalizeRole(role) {
+  if (role === 'tool_result' || role === 'tool' || role === 'toolResult') return ROLE_TOOL_RESULT;
+  if (role === 'assistant') return ROLE_ASSISTANT;
+  if (role === 'user') return ROLE_USER;
+  return role ?? 'unknown';
+}
