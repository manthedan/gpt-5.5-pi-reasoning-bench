+function assignDepths(node, depth, seen, anomalies) {
+  if (seen.has(node.key)) {
+    anomalies.push({
+      type: 'cycle',
+      severity: 'error',
+      message: `Cycle detected at message ${node.id}`,
+      entry: node.entry
+    });
+    return;
+  }
+  node.depth = depth;
+  const nextSeen = new Set(seen);
+  nextSeen.add(node.key);
+  for (const child of node.children) assignDepths(child, depth + 1, nextSeen, anomalies);
