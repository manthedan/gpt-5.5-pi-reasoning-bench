+/**
+ * Parse a Pi-style JSONL session.
+ *
+ * The parser is deliberately forgiving: malformed records are skipped and
+ * reported with line numbers, while valid lines are returned unchanged. Blank
+ * lines are ignored by default because real logs often end with a newline or
+ * contain occasional spacing from manual edits.
+ *
+ * @param {string|Buffer} text JSONL text
+ * @param {{ includeBlankDiagnostics?: boolean }} [options]
+ * @returns {{ entries: any[], diagnostics: Array<object>, lineMap: Array<object> }}
+ */
+export function parseSessionJsonl(text, options = {}) {
+  const source = Buffer.isBuffer(text) ? text.toString('utf8') : String(text ?? '');
+  const lines = source.split(/\r?\n/);
+  const entries = [];
+  const diagnostics = [];
+  const lineMap = [];
+
+  for (let index = 0; index < lines.length; index += 1) {
+    const line = lines[index];
+    const lineNumber = index + 1;
+
+    // Ignore the final empty line from a trailing newline, and by default all
+    // blank lines. Keep an opt-in diagnostic for callers that need strict JSONL.
+    if (line.trim() === '') {
+      if (options.includeBlankDiagnostics && !(index === lines.length - 1 && line === '')) {
+        diagnostics.push({
+          type: 'blank-line',
+          severity: 'info',
+          line: lineNumber,
+          message: 'Blank line ignored',
+          raw: line
+        });
+      }
+      lineMap.push({ line: lineNumber, raw: line, skipped: true });
+      continue;
+    }
+
+    try {
+      const entry = JSON.parse(line);
+      entries.push(entry);
+      lineMap.push({ line: lineNumber, raw: line, entry });
+    } catch (error) {
+      diagnostics.push({
+        type: 'malformed-json',
+        severity: 'error',
+        line: lineNumber,
+        column: extractJsonErrorColumn(error),
+        message: error instanceof Error ? error.message : String(error),
+        raw: line
+      });
+      lineMap.push({ line: lineNumber, raw: line, error });
+    }
+  }
+
+  return { entries, diagnostics, lineMap };
 }
 
