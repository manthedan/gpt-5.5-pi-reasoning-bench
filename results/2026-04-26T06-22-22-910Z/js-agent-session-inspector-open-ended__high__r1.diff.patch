+      entry?.activeMessageId,
+      entry?.currentMessageId,
+      entry?.headId,
+      entry?.lastMessageId,
+      entry?.session?.activeLeafId,
+      entry?.session?.activeMessageId,
+      entry?.session?.currentMessageId
+    ];
+    const found = firstString(...candidates);
+    if (found) return found;
+  }
