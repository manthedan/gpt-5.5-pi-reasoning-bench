+function compareNodesChronologically(a, b) {
+  const aTime = a.timestampMs ?? Number.POSITIVE_INFINITY;
+  const bTime = b.timestampMs ?? Number.POSITIVE_INFINITY;
+  if (aTime !== bTime) return aTime - bTime;
+  return a.order - b.order;
