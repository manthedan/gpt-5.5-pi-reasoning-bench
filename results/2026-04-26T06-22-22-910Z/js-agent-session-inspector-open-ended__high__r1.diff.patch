+export function buildMessageTree(entries, anomalies = [], options = {}) {
+  const nodes = [];
+  const idToNode = new Map();
+  const duplicateCounts = new Map();
+
+  entries.forEach((entry, order) => {
+    if (!isMessageEntry(entry)) return;
+
+    const message = getMessage(entry);
+    const originalId = firstString(entry.id, message.id, entry.messageId, message.messageId);
+    const id = originalId ?? `__message_${order + 1}`;
+    const duplicateNumber = duplicateCounts.get(id) ?? 0;
+    duplicateCounts.set(id, duplicateNumber + 1);
+
+    if (duplicateNumber > 0) {
+      anomalies.push({
+        type: 'duplicate-id',
+        severity: 'warning',
+        message: `Duplicate message id "${id}" encountered; keeping both nodes but parent links target the first occurrence`,
+        entry
+      });
+    }
+
+    if (!originalId) {
+      anomalies.push({
+        type: 'missing-id',
+        severity: 'warning',
+        message: `Message at entry ${order + 1} has no id; generated ${id}`,
+        entry
+      });
+    }
+
+    const node = {
+      key: duplicateNumber > 0 ? `${id}#${duplicateNumber + 1}` : id,
+      id,
+      parentId: normalizeParentId(entry.parentId ?? message.parentId ?? entry.parent_id ?? message.parent_id),
+      entry,
+      message,
+      role: normalizeRole(message.role ?? entry.role ?? entry.type),
+      timestampMs: extractTimestampMs(entry, message),
+      order,
+      children: [],
+      parent: null,
+      depth: 0
+    };
+
+    nodes.push(node);
+    if (!idToNode.has(id)) idToNode.set(id, node);
+  });
+
+  for (const node of nodes) {
+    if (!node.parentId) continue;
+    const parent = idToNode.get(node.parentId);
+    if (!parent) {
+      anomalies.push({
+        type: 'orphan-node',
+        severity: 'warning',
+        message: `Message ${node.id} references missing parent ${node.parentId}`,
+        entry: node.entry
+      });
+      continue;
     }
+    node.parent = parent;
+    parent.children.push(node);
+  }
+
+  for (const node of nodes) {
+    node.children.sort(compareNodesChronologically);
+  }
+
+  const roots = nodes.filter(node => !node.parent);
+  for (const root of roots) assignDepths(root, 0, new Set(), anomalies);
+
+  const leaves = nodes.filter(node => node.children.length === 0);
+  const branchPoints = nodes.filter(node => node.children.length > 1);
+  const requestedActiveId = options.activeLeafId ?? findSessionActiveLeafId(entries);
+  const activeLeaf = requestedActiveId ? (idToNode.get(requestedActiveId) ?? null) : chooseLatestLeaf(leaves);
+  const activePath = activeLeaf ? pathToRoot(activeLeaf) : [];
+
+  if (requestedActiveId && !activeLeaf) {
+    anomalies.push({
+      type: 'missing-active-leaf',
+      severity: 'warning',
+      message: `Requested active leaf ${requestedActiveId} was not found in the message tree`
+    });
+  }
+
+  return {
+    nodes,
+    roots,
+    leaves,
+    branchPoints,
+    activeLeaf,
+    activePath,
+    activePathIds: activePath.map(node => node.id),
+    nodeCount: nodes.length,
+    leafCount: leaves.length,
+    branchCount: branchPoints.length,
+    maxDepth: nodes.reduce((max, node) => Math.max(max, node.depth), 0),
+    byId: idToNode
+  };
+}
