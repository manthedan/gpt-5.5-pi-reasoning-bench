+// Dependency-free utilities for inspecting Pi-style JSONL agent sessions.
+// The public API is intentionally data-oriented so callers can build their own UI
+// or reports on top of the analysis object.
+
+export function parseSessionJsonl(text, options = {}) {
+  const diagnostics = [];
+  const entries = [];
+
+  if (typeof text !== 'string') {
+    throw new TypeError('parseSessionJsonl(text) expects a string');
+  }
+
+  const lines = text.replace(/^\uFEFF/, '').split(/\r?\n/);
+  const keepBlankLines = options.keepBlankLines === true;
+
+  lines.forEach((rawLine, index) => {
+    const lineNumber = index + 1;
+    const line = rawLine.trim();
+
+    // A trailing newline produces a final empty line; do not report it as malformed.
+    if (!line) {
+      if (keepBlankLines && (index !== lines.length - 1 || rawLine.length > 0)) {
+        diagnostics.push({
+          severity: 'warning',
+          kind: 'blank-line',
+          line: lineNumber,
+          message: 'Blank JSONL line ignored',
+          raw: rawLine
+        });
+      }
+      return;
+    }
+
+    try {
+      const value = JSON.parse(line);
+      if (value && typeof value === 'object') {
+        Object.defineProperty(value, '__line', { value: lineNumber, enumerable: false });
+        Object.defineProperty(value, '__raw', { value: rawLine, enumerable: false });
+      }
+      entries.push(value);
+    } catch (error) {
+      diagnostics.push({
+        severity: 'error',
+        kind: 'malformed-json',
+        line: lineNumber,
+        message: error.message,
+        raw: rawLine
+      });
+    }
+  });
+
+  return { entries, diagnostics };
 }
 
